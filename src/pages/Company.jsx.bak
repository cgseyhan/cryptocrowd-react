    linkedin: "https://linkedin.com"
  }
];

// Generates a mathematically computed spiral path string
function generateSpiralPath(cx, cy, startR, endR, turns, points) {
  const path = [];
  for (let i = 0; i <= points; i++) {
    const t = i / points;
    const angle = t * turns * 2 * Math.PI - Math.PI / 2;
    const r = startR + (endR - startR) * t;
    const x = (cx + r * Math.cos(angle)).toFixed(2);
    const y = (cy + r * Math.sin(angle)).toFixed(2);
    path.push(i === 0 ? `M ${x} ${y}` : `L ${x} ${y}`);
  }
  return path.join(' ');
}

function SpiralBackground() {
  // cx+endR <= 990, cx-endR >= 10 (10px margin from edges)
  const miniSpirals = [
    // Tiny (endR: 10-18)
    { cx: 50,  cy: 50,  startR: 2, endR: 12, turns: 2 },
    { cx: 200, cy: 30,  startR: 2, endR: 10, turns: 2 },
    { cx: 420, cy: 22,  startR: 2, endR: 12, turns: 2 },
    { cx: 700, cy: 28,  startR: 2, endR: 12, turns: 2 },
    { cx: 950, cy: 40,  startR: 2, endR: 12, turns: 2 },
    { cx: 28,  cy: 320, startR: 2, endR: 14, turns: 2 },
    { cx: 972, cy: 450, startR: 2, endR: 14, turns: 2 },
    { cx: 50,  cy: 970, startR: 2, endR: 14, turns: 2 },
    { cx: 500, cy: 978, startR: 2, endR: 12, turns: 2 },
    { cx: 950, cy: 965, startR: 2, endR: 14, turns: 2 },
    { cx: 330, cy: 130, startR: 2, endR: 16, turns: 2 },
    { cx: 870, cy: 760, startR: 2, endR: 18, turns: 2 },
    // Small (endR: 22-40)
    { cx: 130, cy: 150, startR: 4, endR: 35, turns: 3 },
    { cx: 650, cy: 200, startR: 4, endR: 38, turns: 3 },
    { cx: 880, cy: 180, startR: 3, endR: 30, turns: 2 },
    { cx: 80,  cy: 510, startR: 3, endR: 25, turns: 2 },
    { cx: 920, cy: 600, startR: 3, endR: 28, turns: 2 },
    { cx: 300, cy: 800, startR: 4, endR: 35, turns: 3 },
    { cx: 700, cy: 820, startR: 3, endR: 30, turns: 3 },
    { cx: 150, cy: 700, startR: 3, endR: 28, turns: 2 },
    { cx: 840, cy: 855, startR: 4, endR: 35, turns: 3 },
    { cx: 380, cy: 170, startR: 3, endR: 28, turns: 3 },
    // Medium (endR: 45-70)
    { cx: 220, cy: 360, startR: 5, endR: 55, turns: 3 },
    { cx: 560, cy: 300, startR: 5, endR: 65, turns: 4 },
    { cx: 790, cy: 450, startR: 5, endR: 60, turns: 3 },
    { cx: 400, cy: 570, startR: 5, endR: 65, turns: 4 },
    { cx: 700, cy: 680, startR: 5, endR: 55, turns: 3 },
    // Large (endR: 75-88)
    { cx: 480, cy: 460, startR: 6, endR: 85, turns: 4 },
    { cx: 160, cy: 540, startR: 6, endR: 80, turns: 3 },
    { cx: 820, cy: 290, startR: 6, endR: 80, turns: 4 },
  ];

  return (
    <div className="absolute inset-0 pointer-events-none z-0" aria-hidden="true">
      <svg
        className="absolute inset-0 w-full h-full opacity-[0.11]"
        viewBox="0 0 1000 1000"
        preserveAspectRatio="xMidYMid slice"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <clipPath id="spiral-clip">
            <rect x="0" y="0" width="1000" height="1000" />
          </clipPath>
        </defs>
        <g clipPath="url(#spiral-clip)">
          <g className="text-white">
            {miniSpirals.map((s, i) => (
              <path
                key={i}
                d={generateSpiralPath(s.cx, s.cy, s.startR, s.endR, s.turns, s.turns * 50)}
                stroke="currentColor"
                strokeWidth="0.9"
                strokeLinecap="round"
              />
            ))}
          </g>
        </g>
      </svg>
    </div>
  );
}

